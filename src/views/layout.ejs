<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>quipudoc</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="menubar">
    <div class="menubar-inner">
      <div class="menubar-left">
        <img src="/img/images.jpeg" alt="Banco de la Nación" class="logo-bn">
        <a href="/repositorio" class="tab <%= currentTab === 'repositorio' ? 'active' : '' %>"><i class="bi bi-folder"></i> Repositorio</a>
        <a href="/tutorial" class="tab <%= currentTab === 'tutorial' ? 'active' : '' %>"><i class="bi bi-book"></i> Tutorial</a>
        <a href="/mis-proyectos" class="tab <%= currentTab === 'mis-proyectos' ? 'active' : '' %>"><i class="bi bi-folder-open"></i> Mis Proyectos</a>
      </div>
      <div class="menubar-right">
        <span class="profile-icon"><i class="bi bi-person"></i></span>
      </div>
    </div>
  </nav>
  <main class="body-content">
    <%- include(pageTemplate, pageData) %>
  </main>

  <button class="chat-fab" onclick="toggleChat()">
    <i class="bi bi-chat-dots"></i>
  </button>

  <div class="chat-overlay" id="chatOverlay" onclick="toggleChat()"></div>
  <div class="chat-modal" id="chatModal">
    <div class="chat-header">
      <span><i class="bi bi-robot"></i> Asistente quipudoc</span>
      <button class="chat-close" onclick="toggleChat()"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="chat-messages" id="chatMessages">
      <div class="msg msg-assistant">
        <div class="msg-content">
          ¡Hola! Soy tu asistente. Puedes preguntarme sobre los documentos del Banco de la Nación que hayas subido.
        </div>
      </div>
    </div>
    <div class="chat-input-area">
      <input type="text" class="chat-input" id="chatInput" placeholder="Escribe tu pregunta..." onkeydown="if(event.key==='Enter') sendChat()">
      <button class="chat-send" onclick="sendChat()"><i class="bi bi-send-fill"></i></button>
    </div>
  </div>

  <script>
  function getSessionId() {
    let sid = localStorage.getItem('chatSessionId');
    if (!sid) {
      sid = crypto.randomUUID();
      localStorage.setItem('chatSessionId', sid);
    }
    return sid;
  }

  function toggleChat() {
    document.getElementById('chatOverlay').classList.toggle('show');
    document.getElementById('chatModal').classList.toggle('show');
    if (document.getElementById('chatModal').classList.contains('show')) {
      document.getElementById('chatInput').focus();
    }
  }

  async function sendChat() {
    const input = document.getElementById('chatInput');
    const text = input.value.trim();
    if (!text) return;

    const messages = document.getElementById('chatMessages');

    const userMsg = document.createElement('div');
    userMsg.className = 'msg msg-user';
    userMsg.innerHTML = '<div class="msg-content">' + escapeHtml(text) + '</div>';
    messages.appendChild(userMsg);

    input.value = '';

    const typing = document.createElement('div');
    typing.className = 'msg msg-assistant';
    typing.id = 'typingIndicator';
    typing.innerHTML = '<div class="msg-content"><i class="bi bi-three-dots"></i></div>';
    messages.appendChild(typing);
    messages.scrollTop = messages.scrollHeight;

    try {
      const res = await fetch('/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, sessionId: getSessionId() }),
      });

      document.getElementById('typingIndicator')?.remove();

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Error en el servidor');
      }

      const data = await res.json();

      const reply = document.createElement('div');
      reply.className = 'msg msg-assistant';
      reply.innerHTML = '<div class="msg-content">' + escapeHtml(data.reply) + '</div>';
      messages.appendChild(reply);
    } catch (err) {
      document.getElementById('typingIndicator')?.remove();
      const reply = document.createElement('div');
      reply.className = 'msg msg-assistant';
      reply.innerHTML = '<div class="msg-content" style="color:#AF272F">Error: ' + escapeHtml(err.message) + '</div>';
      messages.appendChild(reply);
    }

    messages.scrollTop = messages.scrollHeight;
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
  </script>
</body>
</html>
